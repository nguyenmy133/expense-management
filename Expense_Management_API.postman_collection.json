              }
            ],
            "url": {
              "raw": "{{baseUrl}}/chat/history?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "history"],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "Clear Chat History",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/chat/history",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "history"]
            }
          }
        }
      ]
    }
  ]
}
